async function salvarCombo() {
  const nome = document.getElementById("combo-nome").value.trim();
  const preco = parseFloat(document.getElementById("combo-preco").value) || 0;
  if (!nome || !preco) { toast("Preencha nome e preço.", "error"); return; }
  if (!_comboItensTemp.length) { toast("Adicione ao menos um produto.", "error"); return; }
  const id = document.getElementById("combo-id").value;
  let comboId = id;
  if (id) {
    await db.from('combos').update({ nome, preco }).eq('id', id);
    await db.from('combo_itens').delete().eq('combo_id', id);
  } else {
    const { data } = await db.from('combos').insert([{ cliente_id: _clienteId, nome, preco }]).select().single();
