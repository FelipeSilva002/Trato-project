async function registrar(){
  if(!produtoAtual)return;
  const q=qtdAtual,obs=document.getElementById("obs-input").value.trim();
  const now=new Date(),hora=now.toLocaleTimeString("pt-BR",{hour:"2-digit",minute:"2-digit"}),data=now.toLocaleDateString("pt-BR");
  const existe=estoque.find(p=>p.codigo===produtoAtual.codigo);

  if(existe){
    // Produto já existe — atualiza quantidade no banco
    const novaQtd = tipoAtual==="entrada" ? existe.quantidade+q : Math.max(0,existe.quantidade-q);
    const { error } = await db.from('produtos').update({ quantidade: novaQtd }).eq('id', existe.id);
    if(error){ toast("Erro ao atualizar estoque.","error"); console.error(error); return; }
    existe.quantidade = novaQtd;
  } else {
    // Produto novo — insere no banco
    const minimoDefinido = parseInt(document.getElementById("pf-minimo").value)||6;
    const precoDefinido  = parseFloat(document.getElementById("pf-preco").value)||0;
    const novoProduto = {
      cliente_id: _clienteId,
      codigo: produtoAtual.codigo,
      nome: produtoAtual.nome,
      marca: produtoAtual.marca,
      categoria: produtoAtual.categoria,
      quantidade: tipoAtual==="entrada"?q:0,
      minimo: minimoDefinido,
      preco: precoDefinido
    };
    const { data: inserted, error } = await db.from('produtos').insert([novoProduto]).select().single();
    if(error){ toast("Erro ao cadastrar produto.","error"); console.error(error); return; }
    estoque.push(inserted);
    if(!FOTOS[produtoAtual.codigo])FOTOS[produtoAtual.codigo]=null;
  }

  historico.push({id:historico.length+1,data,hora,produto:produtoAtual.nome,codigo:produtoAtual.codigo,tipo:tipoAtual,qtd:q,obs});
  renderDashboard();
  renderPDVGrid();
  renderProdutos();
  toast(`${tipoAtual==="entrada"?"Entrada":"Saída"} registrada — ${q} un. de ${produtoAtual.nome}`,"ok");
  resetPanel();
}

