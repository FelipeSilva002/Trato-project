function iniciarQuagga(){
  if(scannerRodando)return;
  Quagga.init({
    inputStream:{name:"Live",type:"LiveStream",target:document.getElementById("scanner-viewport"),constraints:{facingMode:"environment",width:{ideal:1280},height:{ideal:720}}},
    decoder:{readers:["ean_reader","ean_8_reader","upc_reader","upc_e_reader","code_128_reader"]},
    locate:true
  },
  err=>{if(err){toast("Câmera indisponível. Use o campo manual.","error");return;}Quagga.start();scannerRodando=true;});
  
  let _ultimo = null;
  Quagga.onDetected(r=>{
    const c = r.codeResult.code;
    // Aceita apenas EAN-8 (8 dígitos) ou EAN-13 (13 dígitos)
    if(!c || (c.length !== 8 && c.length !== 13)) return;
    // Exige leitura do mesmo código 2 vezes seguidas
    if(c === _ultimo){
      pararQuagga();
      _ultimo = null;
      buscarProduto(c);
    } else {
      _ultimo = c;
    }
  });
}
function pararQuagga(){if(!scannerRodando)return;try{Quagga.stop();}catch{}scannerRodando=false;}
