// Leitor bip no PDV — adiciona direto ao carrinho sequencialmente
function abrirBipPDV() {
  document.getElementById("pdv-bip-modal").classList.add("open");
  document.getElementById("pdv-bip-log").innerHTML = "";
  setTimeout(() => document.getElementById("pdv-bip-input").focus(), 100);
}
function fecharBipPDV() {
  document.getElementById("pdv-bip-modal").classList.remove("open");
  document.getElementById("pdv-bip-input").value = "";
}

document.getElementById("pdv-bip-input").addEventListener("keydown", e => {
  if (e.key === "Enter") {
    const codigo = e.target.value.trim();
    e.target.value = "";
    if (!codigo) return;
    const p = estoque.find(x => x.codigo === codigo);
    const log = document.getElementById("pdv-bip-log");
    if (!p) {
      log.innerHTML = `<div style="padding:8px 10px;background:var(--red-dim);border-radius:6px;margin-bottom:6px;font-size:12px;color:var(--red)">❌ Código <b>${codigo}</b> não encontrado</div>` + log.innerHTML;
      toast("Produto não encontrado!", "error");
    } else if (p.quantidade <= 0) {
      log.innerHTML = `<div style="padding:8px 10px;background:var(--yellow-dim);border-radius:6px;margin-bottom:6px;font-size:12px;color:var(--yellow)">⚠️ <b>${p.nome}</b> — sem estoque</div>` + log.innerHTML;
      toast("Produto sem estoque!", "error");
    } else {
      adicionarAoCarrinho(codigo);
      const item = carrinho.find(x => x.codigo === codigo);
      log.innerHTML = `<div style="padding:8px 10px;background:var(--green-dim);border-radius:6px;margin-bottom:6px;font-size:12px;color:var(--green)">✅ <b>${p.nome}</b> — ${item?.qtd || 1} un. no carrinho</div>` + log.innerHTML;
    }
    e.target.focus();
  }
});

