    document.getElementById("pgto-1-valor-box").style.display = "block";
    document.getElementById("pgto-1-valor").placeholder = "Valor na 1ª forma (R$)";
    document.getElementById("pgto-2-section").style.display = "block";
    // Preencher valor padrão com total
    if (!document.getElementById("pgto-1-valor").value) {
      document.getElementById("pgto-1-valor").value = total.toFixed(2);
    }
  }

  if (num === 2) {
    document.getElementById("pgto-2-valor-box").style.display = "block";
    const v1 = parseFloat(document.getElementById("pgto-1-valor").value) || 0;
    const restante = Math.max(0, total - v1);
    document.getElementById("pgto-2-valor").value = restante.toFixed(2);
  }

  atualizarPgto();
}

function atualizarPgto() {
  if (!window._pgto) return;
  const total = carrinho.reduce((a,b) => a + b.preco * b.qtd, 0);
  const v1 = parseFloat(document.getElementById("pgto-1-valor").value) || 0;
  const v2 = parseFloat(document.getElementById("pgto-2-valor")?.value) || 0;
  const restante = total - v1;

  document.getElementById("pgto-restante").textContent = "R$ " + Math.max(0, restante).toFixed(2).replace(".",",");
  window._pgto.v1 = v1;
  window._pgto.v2 = v2;

  // Troco — só se alguma forma for dinheiro
  const temDinheiro = window._pgto.p1 === "dinheiro" || window._pgto.p2 === "dinheiro";
  const totalPago = window._pgto.p2 ? v1 + v2 : v1;
  const troco = totalPago - total;

  if (temDinheiro && totalPago > 0) {
    document.getElementById("pgto-troco-box").classList.add("show");
    document.getElementById("pgto-troco-valor").textContent = troco >= 0
      ? "R$ " + troco.toFixed(2).replace(".",",")
      : "⚠️ Falta R$ " + Math.abs(troco).toFixed(2).replace(".",",");
    document.getElementById("pgto-troco-valor").style.color = troco >= 0 ? "var(--blue)" : "var(--red)";
  } else {
    document.getElementById("pgto-troco-box").classList.remove("show");
  }

  // Habilitar confirmar
  const p1ok = window._pgto.p1 && v1 > 0;
  const p2ok = !window._pgto.p2 || (window._pgto.p2 && v2 > 0 && Math.abs(v1 + v2 - total) < 0.01);
  const somenteP1 = window._pgto.p1 && !window._pgto.p2 && Math.abs(v1 - total) < 0.01;
  document.getElementById("pgto-confirmar-btn").disabled = !(somenteP1 || (p1ok && p2ok));
}

function calcularTroco() { atualizarPgto(); }

function fecharPgto() {
  document.getElementById("pgto-modal").classList.remove("open");
}

async function confirmarPagamento() {
  if (!window._pgto?.p1) return;
  const total = carrinho.reduce((a,b) => a + b.preco * b.qtd, 0);
  const now = new Date();
  const hora = now.toLocaleTimeString("pt-BR",{hour:"2-digit",minute:"2-digit"});
  const data = now.toLocaleDateString("pt-BR");
  const labels = { dinheiro:"💵 Dinheiro", pix:"📱 Pix", cartao:"💳 Cartão" };
  const p1 = labels[window._pgto.p1];
  const p2 = window._pgto.p2 ? labels[window._pgto.p2] : null;
  const v1 = window._pgto.v1;
  const v2 = window._pgto.v2;
  const pgtoLabel = p2
    ? `${p1} R$${v1.toFixed(2)} + ${p2} R$${v2.toFixed(2)}`
    : `${p1}`;

  // Montar registros para salvar no banco
  const registrosVenda = [];

  carrinho.forEach(item => {
    if (item.isCombo) {
      (item.comboItens||[]).forEach(ci => {
        const p = estoque.find(x => x.id === ci.produto_id);
        if (p) {
          p.quantidade = Math.max(0, p.quantidade - (ci.quantidade * item.qtd));
          db.from('produtos').update({ quantidade: p.quantidade }).eq('id', p.id);
        }
      });
    } else {
      const p = estoque.find(x => x.codigo === item.codigo);
      if (p) {
        p.quantidade = Math.max(0, p.quantidade - item.qtd);
        db.from('produtos').update({ quantidade: p.quantidade }).eq('id', p.id);
      }
    }
    const itemTotal = item.preco * item.qtd;
    historico.push({
      id: historico.length + 1, data, hora,
      produto: item.nome, codigo: item.codigo,
      preco: item.preco,
      tipo: "saida", qtd: item.qtd,
      obs: `PDV ${pgtoLabel} — R$ ${itemTotal.toFixed(2)}`
    });
    registrosVenda.push({
      cliente_id: _clienteId,
      caixa_id: _caixaAtual?.id || null,
      produto: item.nome,
      codigo: item.codigo,
      qtd: item.qtd,
      preco: item.preco,
      total: itemTotal,
      forma_pgto: p1,
      forma_pgto2: p2 || null,
      valor_pgto1: v1,
      valor_pgto2: v2 || null,
      obs: pgtoLabel
    });
  });

  // Salvar vendas no banco
  if (registrosVenda.length > 0) {
    db.from('vendas').insert(registrosVenda);
  }

  fecharPgto();
  toast(`✅ Venda finalizada — R$ ${total.toFixed(2).replace(".",",")} via ${pgtoLabel}`, "ok");
  limparCarrinho();
  renderDashboard();
  renderPDVGrid();
}

