const LABELS={"dashboard":"Dashboard","produtos":"Produtos","venda":"PDV / Venda","movimentacoes":"Movimentações","relatorio":"Relatório Diário","fiado":"Fiado / Contas","combos":"Combos","mesas":"Mesas","caixa":"Caixa"};
const ABAS=["venda","combos","mesas","dashboard","produtos","movimentacoes","fiado","relatorio","caixa"];

function nav(aba){
  document.querySelectorAll(".page-view").forEach(v=>v.classList.remove("active"));
  document.querySelectorAll(".nav-item").forEach(n=>{
    const onclick = n.getAttribute("onclick")||"";
    const match = onclick.match(/nav\('([^']+)'\)/);
    if(match) n.classList.toggle("active", match[1]===aba);
  });
  document.getElementById("view-"+aba).classList.add("active");
  document.getElementById("breadcrumb").textContent=LABELS[aba]||aba;
  if(aba==="produtos")renderProdutos();
  if(aba==="venda"){ renderVenda(); setTimeout(()=>{ const el=document.getElementById("pdv-bip-global"); if(el) el.focus(); },150); }
  if(aba==="movimentacoes")renderMovimentacoes();
  if(aba==="relatorio")renderRelatorio();
  if(aba==="caixa"){ renderCaixa(); return; }
  if(aba==="fiado"){ carregarFiado(); return; }
  if(aba==="combos"){ carregarCombos(); return; }
  if(aba==="mesas"){ carregarMesas(); return; }

}

