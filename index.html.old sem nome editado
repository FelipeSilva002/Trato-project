async function adicionarItemMesa(produtoId, nome, preco) {
  if (!mesaAtual) return;
  const p = estoque.find(x => x.id === produtoId);
  if (p && p.quantidade <= 0) { toast(`${nome} sem estoque!`, "error"); return; }
  // Verificar se já existe na mesa
  const existe = mesaAtual.mesa_itens.find(i => i.produto_id === produtoId);
  if (existe) {
    const { error } = await db.from('mesa_itens').update({ quantidade: existe.quantidade + 1 }).eq('id', existe.id);
    if (!error) { existe.quantidade++; }
  } else {
    const { data, error } = await db.from('mesa_itens').insert([{ mesa_id: mesaAtual.id, produto_id: produtoId, nome, preco, quantidade: 1 }]).select().single();
    if (!error) mesaAtual.mesa_itens.push(data);
  }
  // Descontar do estoque
  if (p) { p.quantidade = Math.max(0, p.quantidade - 1); await db.from('produtos').update({ quantidade: p.quantidade }).eq('id', p.id); }
  document.getElementById("mesa-busca-produto").value = "";
  document.getElementById("mesa-busca-resultado").innerHTML = "";
  renderItensMesa();
  toast(`${nome} adicionado!`, "ok");
}

async function removerItemMesa(itemId) {
  if (!mesaAtual) return;
  const item = mesaAtual.mesa_itens.find(i => i.id === itemId);
  if (!item) return;
  // Devolver ao estoque
  const p = estoque.find(x => x.id === item.produto_id);
  if (p) { p.quantidade += item.quantidade; await db.from('produtos').update({ quantidade: p.quantidade }).eq('id', p.id); }
  await db.from('mesa_itens').delete().eq('id', itemId);
  mesaAtual.mesa_itens = mesaAtual.mesa_itens.filter(i => i.id !== itemId);
  renderItensMesa();
}

async function fecharMesaConfirmar() {
  if (!mesaAtual) return;
  const itens = mesaAtual.mesa_itens || [];
  if (!itens.length) { toast("Adicione itens antes de fechar.", "error"); return; }
  const total = itens.reduce((a,i) => a + parseFloat(i.preco) * i.quantidade, 0);
  const numeroMesa = mesaAtual.numero;
  if (!confirm(`Enviar pedidos da ${numeroMesa} para o carrinho?\nTotal: R$ ${total.toFixed(2).replace(".",",")}`)) return;

  // Jogar todos os itens no carrinho do PDV
  itens.forEach(item => {
    const existe = carrinho.find(x => x.codigo === item.produto_id);
    if (existe) {
      existe.qtd += item.quantidade;
    } else {
      carrinho.push({
        codigo: item.produto_id,
        nome: item.nome,
        preco: parseFloat(item.preco),
        qtd: item.quantidade
      });
    }
  });

  // Zerar itens da mesa no banco
  await db.from('mesa_itens').delete().eq('mesa_id', mesaAtual.id);
  mesaAtual.mesa_itens = [];

  // Fechar modal e ir para PDV
  document.getElementById("mesa-pedido-modal").classList.remove("open");
  mesaAtual = null;
  renderMesas();
  nav("venda");
  renderCarrinho();
  toast(`✅ Itens da ${numeroMesa} enviados ao carrinho! Total: R$ ${total.toFixed(2).replace(".",",")}`, "ok");
}

// ── CALCULADORA ────────────────────────────────────────
let _calc = { expr: "", result: "0", aguardaOperando: false, operador: null, valorAnterior: null };

function abrirCalculadora() {
  _calc = { expr: "", result: "0", aguardaOperando: false, operador: null, valorAnterior: null };
  atualizarCalc();
  document.getElementById("calc-modal").classList.add("open");
}
function fecharCalculadora() { document.getElementById("calc-modal").classList.remove("open"); }

function atualizarCalc() {
  document.getElementById("calc-result").textContent = _calc.result;
  document.getElementById("calc-expr").textContent = _calc.expr;
}

function calcOp(op) {
  const cur = parseFloat(_calc.result) || 0;
  if (op === "AC") {
    _calc = { expr: "", result: "0", aguardaOperando: false, operador: null, valorAnterior: null };
  } else if (!isNaN(op) || op === ".") {
    if (_calc.aguardaOperando) {
      _calc.result = op === "." ? "0." : op;
      _calc.aguardaOperando = false;
    } else {
      if (op === "." && _calc.result.includes(".")) return;
      _calc.result = _calc.result === "0" && op !== "." ? op : _calc.result + op;
    }
  } else if (["+", "-", "*", "/"].includes(op)) {
    if (_calc.operador && !_calc.aguardaOperando) {
      const res = calcular(_calc.valorAnterior, cur, _calc.operador);
      _calc.result = formatarCalc(res);
      _calc.valorAnterior = res;
    } else {
      _calc.valorAnterior = cur;
    }
    _calc.expr = _calc.result + " " + {"+":"+","-":"−","*":"×","/":"÷"}[op];
    _calc.operador = op;
    _calc.aguardaOperando = true;
  } else if (op === "=") {
    if (_calc.operador && _calc.valorAnterior !== null) {
      const res = calcular(_calc.valorAnterior, cur, _calc.operador);
      _calc.expr = "";
      _calc.result = formatarCalc(res);
      _calc.operador = null;
      _calc.valorAnterior = null;
      _calc.aguardaOperando = true;
    }
  } else if (op === "%") {
    _calc.result = formatarCalc(cur / 100);
  } else if (op === "+/-") {
    _calc.result = formatarCalc(-cur);
  }
  atualizarCalc();
}

function calcular(a, b, op) {
  if (op === "+") return a + b;
  if (op === "-") return a - b;
  if (op === "*") return a * b;
  if (op === "/") return b !== 0 ? a / b : 0;
}

function formatarCalc(n) {
  if (isNaN(n) || !isFinite(n)) return "0";
  return parseFloat(n.toFixed(10)).toString();
}

document.addEventListener("keydown", e => {
  if (!document.getElementById("calc-modal").classList.contains("open")) return;
  if (e.key === "Escape") { fecharCalculadora(); return; }
  if ("0123456789".includes(e.key)) calcOp(e.key);
  else if (e.key === ".") calcOp(".");
  else if (e.key === "+") calcOp("+");
  else if (e.key === "-") calcOp("-");
  else if (e.key === "*") calcOp("*");
  else if (e.key === "/") { e.preventDefault(); calcOp("/"); }
  else if (e.key === "Enter" || e.key === "=") calcOp("=");
  else if (e.key === "Backspace") {
    _calc.result = _calc.result.length > 1 ? _calc.result.slice(0,-1) : "0";
    atualizarCalc();
  }
});

