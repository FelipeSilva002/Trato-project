function filtrarPeriodo(periodo,btn){
  filtroPeriodo=periodo;
  document.querySelectorAll(".periodo-btn").forEach(b=>b.classList.remove("active"));
  btn.classList.add("active");
  const custom=document.getElementById("periodo-custom");
  if(periodo==="custom"){
    custom.classList.add("show");
    // Define datas padrão: últimos 7 dias
    const hoje=new Date();
    const seteDias=new Date(hoje);
    seteDias.setDate(hoje.getDate()-7);
    document.getElementById("data-inicio").value=seteDias.toISOString().split("T")[0];
    document.getElementById("data-fim").value=hoje.toISOString().split("T")[0];
  } else {
    custom.classList.remove("show");
    renderMovimentacoes();
  }
}

function filtrarPorPeriodo(lista){
  const hoje=new Date();
  const hojeStr=hoje.toLocaleDateString("pt-BR");

  if(filtroPeriodo==="hoje"){
    return lista.filter(h=>h.data===hojeStr);
  }
  if(filtroPeriodo==="semana"){
    const ini=new Date(hoje); ini.setDate(hoje.getDate()-7);
    return lista.filter(h=>{
      const [d,m,a]=h.data.split("/");
      const dt=new Date(`${a}-${m}-${d}`);
      return dt>=ini && dt<=hoje;
    });
  }
  if(filtroPeriodo==="mes"){
    return lista.filter(h=>{
      const [,m,a]=h.data.split("/");
      return parseInt(m)===hoje.getMonth()+1 && parseInt(a)===hoje.getFullYear();
    });
  }
  if(filtroPeriodo==="custom"){
    const ini=document.getElementById("data-inicio").value;
    const fim=document.getElementById("data-fim").value;
    if(!ini||!fim) return lista;
    return lista.filter(h=>{
      const [d,m,a]=h.data.split("/");
      const dt=`${a}-${m.padStart(2,"0")}-${d.padStart(2,"0")}`;
      return dt>=ini && dt<=fim;
    });
  }
  return lista; // tudo
}

