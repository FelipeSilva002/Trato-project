async function renderMovimentos() {
  if (!_caixaAtual) return;
  const { data: movs } = await db
    .from('caixa_movimentos')
    .select('*')
    .eq('caixa_id', _caixaAtual.id)
    .order('criado_em', { ascending: false });

  const lista = document.getElementById("caixa-movimentos-lista");
  const totalSangria = (movs||[]).filter(m => m.tipo === "sangria").reduce((a,m) => a + parseFloat(m.valor||0), 0);
  const totalSuprimento = (movs||[]).filter(m => m.tipo === "suprimento").reduce((a,m) => a + parseFloat(m.valor||0), 0);

  // Atualizar KPI sangria e esperado
  document.getElementById("caixa-kpi-sangria").textContent = "R$ " + totalSangria.toFixed(2).replace(".",",");
  if (window._caixaTotais) {
    const novoEsperado = window._caixaTotais.totalDinheiro + parseFloat(_caixaAtual.valor_abertura||0) - totalSangria + totalSuprimento;
    window._caixaTotais.esperado = novoEsperado;
    document.getElementById("caixa-kpi-esperado").textContent = "R$ " + novoEsperado.toFixed(2).replace(".",",");
    // Recalcular diferença se já tiver valor contado
    const contado = parseFloat(document.getElementById("caixa-valor-contado").value) || 0;
    if (contado) calcularDiferenca();
  }

  if (!movs?.length) {
    lista.innerHTML = '<div style="padding:12px 0;font-size:13px;color:var(--text3)">Nenhum movimento registrado.</div>';
    return;
  }
  lista.innerHTML = movs.map(m => {
    const isSangria = m.tipo === "sangria";
    return `<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)">
      <div>
        <div style="font-size:13px;font-weight:600;color:${isSangria?"var(--red)":"var(--green)"}">${isSangria?"− Sangria":"+ Suprimento"}</div>
        <div style="font-size:11px;color:var(--text3)">${m.descricao} · ${new Date(m.criado_em).toLocaleTimeString("pt-BR",{hour:"2-digit",minute:"2-digit"})}</div>
      </div>
      <span style="font-weight:700;color:${isSangria?"var(--red)":"var(--green)"}">R$ ${parseFloat(m.valor).toFixed(2).replace(".",",")}</span>
    </div>`;
  }).join("");
}

