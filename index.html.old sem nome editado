async function excluirProduto() {
  const codigo = document.getElementById("edit-codigo").value;
  const p = estoque.find(x => x.codigo === codigo);
  if (!p) return;
  if (!confirm("Tem certeza que deseja excluir este produto?")) return;

  const { error } = await db
    .from('produtos')
    .delete()
    .eq('id', p.id);

  if (error) {
    toast("Erro ao excluir produto.", "error");
    console.error(error);
    return;
  }

  estoque = estoque.filter(p => p.codigo !== codigo);
  fecharEdicao();
  renderProdutos();
  renderDashboard();
  toast("Produto excluído.", "ok");
}

