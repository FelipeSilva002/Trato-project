async function selecionarProdutoFiado(id, nome, preco, estoqueQtd) {
  if (estoqueQtd <= 0) {
    if (!confirm(`${nome} está sem estoque. Lançar mesmo assim?`)) return;
  }
  const valor = parseFloat(preco) || 0;
  const desc = `${nome} x1`;
  const now = new Date();
  const data = now.toLocaleDateString("pt-BR");
  const hora = now.toLocaleTimeString("pt-BR",{hour:"2-digit",minute:"2-digit"});

  // Descontar do estoque
  const p = estoque.find(x => x.id === id);
  if (p && p.quantidade > 0) {
    p.quantidade = Math.max(0, p.quantidade - 1);
    await db.from('produtos').update({ quantidade: p.quantidade }).eq('id', p.id);
  }

  const { data: lanc, error } = await db
    .from('fiado_lancamentos')
    .insert([{ fiado_cliente_id: clienteAtual.id, tipo:"debito", descricao:desc, valor, data, hora }])
    .select().single();
  if (error) { toast("Erro ao lançar.", "error"); console.error(error); return; }
  clienteAtual.lancamentos.push(lanc);

  // Adicionar à lista da sessão
  window._flItensLancados = window._flItensLancados || [];
  window._flItensLancados.push({ desc, valor });
  renderMiniHistoricoFiado();

  // Limpar busca para próximo item
  document.getElementById("fl-busca-produto").value = "";
  document.getElementById("fl-busca-resultado").innerHTML = "";
  document.getElementById("fl-estoque-aviso").style.display = "none";
  renderDetalhe();
  renderFiado();
  renderPDVGrid();
  toast(`✅ ${nome} — R$ ${valor.toFixed(2).replace(".",",")} lançado!`, "ok");
  setTimeout(() => document.getElementById("fl-busca-produto").focus(), 50);
}

