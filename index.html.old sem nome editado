let _caixaAtual = null;

async function renderCaixa() {
  // Buscar caixa aberto do dia
  const { data } = await db
    .from('caixas')
    .select('*')
    .eq('cliente_id', _clienteId)
    .eq('status', 'aberto')
    .order('abertura_em', { ascending: false })
    .limit(1);
  _caixaAtual = data?.[0] || null;

  if (_caixaAtual) {
    mostrarCaixaAberto();
  } else {
    mostrarCaixaFechado();
  }
}

function mostrarCaixaFechado() {
  document.getElementById("caixa-fechado").style.display = "block";
  document.getElementById("caixa-aberto").style.display = "none";
  document.getElementById("caixa-subtitle").textContent = "Nenhum caixa aberto";
  document.getElementById("caixa-valor-abertura").value = "";
  document.getElementById("caixa-obs-abertura").value = "";
}

async function mostrarCaixaAberto() {
  document.getElementById("caixa-fechado").style.display = "none";
  document.getElementById("caixa-aberto").style.display = "block";
  const abertura = new Date(_caixaAtual.abertura_em);
  document.getElementById("caixa-subtitle").textContent = `Aberto às ${abertura.toLocaleTimeString("pt-BR",{hour:"2-digit",minute:"2-digit"})} de ${abertura.toLocaleDateString("pt-BR")}`;
  document.getElementById("caixa-kpi-abertura").textContent = "R$ " + parseFloat(_caixaAtual.valor_abertura||0).toFixed(2).replace(".",",");
  document.getElementById("caixa-kpi-hora").textContent = abertura.toLocaleTimeString("pt-BR",{hour:"2-digit",minute:"2-digit"});

  // Buscar vendas do banco desde abertura do caixa
  const { data: vendas } = await db
    .from('vendas')
    .select('*')
    .eq('cliente_id', _clienteId)
    .gte('criado_em', _caixaAtual.abertura_em)
    .order('criado_em', { ascending: false });

  let totalDinheiro = 0, totalPix = 0, totalCartao = 0;
  (vendas || []).forEach(v => {
    const f1 = (v.forma_pgto||"").toLowerCase();
    const f2 = (v.forma_pgto2||"").toLowerCase();
    const vt = parseFloat(v.total||0);
    const v1 = parseFloat(v.valor_pgto1||0);
    const v2 = parseFloat(v.valor_pgto2||0);
    const totalPgto = v2 > 0 ? v1 + v2 : v1;
    if (f2) {
      if (f1.includes("dinheiro")) totalDinheiro += (v1/(totalPgto||1)) * vt;
      else if (f1.includes("pix")) totalPix += (v1/(totalPgto||1)) * vt;
      else if (f1.includes("cartão")||f1.includes("cartao")) totalCartao += (v1/(totalPgto||1)) * vt;
      if (f2.includes("dinheiro")) totalDinheiro += (v2/(totalPgto||1)) * vt;
      else if (f2.includes("pix")) totalPix += (v2/(totalPgto||1)) * vt;
      else if (f2.includes("cartão")||f2.includes("cartao")) totalCartao += (v2/(totalPgto||1)) * vt;
    } else {
      if (f1.includes("dinheiro")) totalDinheiro += vt;
      else if (f1.includes("pix")) totalPix += vt;
      else if (f1.includes("cartão")||f1.includes("cartao")) totalCartao += vt;
      else totalDinheiro += vt;
    }
  });

  const totalVendas = totalDinheiro + totalPix + totalCartao;
  const esperado = parseFloat(_caixaAtual.valor_abertura||0) + totalDinheiro;

  document.getElementById("caixa-kpi-dinheiro").textContent = "R$ " + totalDinheiro.toFixed(2).replace(".",",");
  document.getElementById("caixa-kpi-pix").textContent = "R$ " + totalPix.toFixed(2).replace(".",",");
  document.getElementById("caixa-kpi-cartao").textContent = "R$ " + totalCartao.toFixed(2).replace(".",",");
  document.getElementById("caixa-kpi-total").textContent = "R$ " + totalVendas.toFixed(2).replace(".",",");
  document.getElementById("caixa-kpi-esperado").textContent = "R$ " + esperado.toFixed(2).replace(".",",");

  // Lista de vendas agrupadas
  const lista = document.getElementById("caixa-vendas-lista");
  if (!vendas?.length) {
    lista.innerHTML = '<div style="padding:12px 0;font-size:13px;color:var(--text3)">Nenhuma venda registrada ainda.</div>';
  } else {
    const grupos = {};
    vendas.forEach(v => {
      const key = (v.criado_em||"").slice(0,16) + "_" + (v.obs||"");
      if (!grupos[key]) grupos[key] = { itens:[], total:0, hora:new Date(v.criado_em).toLocaleTimeString("pt-BR",{hour:"2-digit",minute:"2-digit"}), forma:v.obs||"—" };
      grupos[key].itens.push(v);
      grupos[key].total += parseFloat(v.total||0);
    });
    lista.innerHTML = Object.values(grupos).map(g => `
      <div style="padding:10px 0;border-bottom:1px solid var(--border)">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
          <span style="font-size:12px;color:var(--text3)">${g.hora} · ${g.forma}</span>
          <span style="font-size:14px;font-weight:800;color:var(--green)">R$ ${g.total.toFixed(2).replace(".",",")}</span>
        </div>
        ${g.itens.map(i => `<div style="font-size:12px;color:var(--text2);padding-left:8px">${i.qtd}x ${i.produto}</div>`).join("")}
      </div>`).join("");
  }

  document.getElementById("caixa-valor-contado").value = "";
  document.getElementById("caixa-diferenca-box").style.display = "none";
  window._caixaTotais = { totalDinheiro, totalPix, totalCartao, totalVendas, esperado };
  // Carregar movimentos
  await renderMovimentos();
}

function calcularDiferenca() {
  const contado = parseFloat(document.getElementById("caixa-valor-contado").value) || 0;
  if (!contado && contado !== 0) { document.getElementById("caixa-diferenca-box").style.display = "none"; return; }
  const esperado = window._caixaTotais?.esperado || 0;
  const diferenca = contado - esperado;
  const box = document.getElementById("caixa-diferenca-box");
  box.style.display = "block";
  box.style.background = diferenca >= 0 ? "var(--green-dim)" : "var(--red-dim)";
  document.getElementById("caixa-diferenca-label").textContent = diferenca >= 0 ? "✅ Sobra no caixa" : "⚠️ Falta no caixa";
  document.getElementById("caixa-diferenca-valor").textContent = "R$ " + Math.abs(diferenca).toFixed(2).replace(".",",");
  document.getElementById("caixa-diferenca-valor").style.color = diferenca >= 0 ? "var(--green)" : "var(--red)";
}

