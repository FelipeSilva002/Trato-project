function adicionarAoCarrinho(codigo) {
  const p = estoque.find(x => x.codigo === codigo);
  if (!p) return;
  if (p.quantidade <= 0) { toast("Produto sem estoque!", "error"); return; }
  const item = carrinho.find(x => x.codigo === codigo);
  if (item) {
    if (item.qtd >= p.quantidade) { toast("Quantidade máxima atingida!", "error"); return; }
    item.qtd++;
  } else {
    carrinho.push({ codigo: p.codigo, nome: p.nome, preco: p.preco||0, qtd: 1, max: p.quantidade });
