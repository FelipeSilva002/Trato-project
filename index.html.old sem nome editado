async function buscarProduto(codigo){
  fecharScanner();
  // Esconde grid antes de navegar para evitar flash
  document.getElementById("produtos-grid-wrap").classList.add("hidden");
  document.getElementById("form-panel").classList.remove("hidden");
  document.getElementById("state-loading").classList.remove("hidden");
  document.getElementById("state-produto").classList.add("hidden");
  nav("produtos");
  const existente=estoque.find(p=>p.codigo===codigo);
  if(existente){mostrarProduto({...existente,novo:false});return;}
  try{
    const res=await fetch(`https://world.openfoodfacts.org/api/v0/product/${codigo}.json`);
    const data=await res.json();
    console.log("OpenFoodFacts:", data.status, data.product?.product_name);
    if(data.status===1&&data.product){
      const p=data.product,nome=p.product_name_pt||p.product_name||"Produto "+codigo.slice(-4),marca=p.brands||"—";
      const cat=(p.categories||"").toLowerCase();
      let categoria="Outro";
      if(cat.includes("wine")||cat.includes("vinho"))categoria="Vinho";
      else if(cat.includes("beer")||cat.includes("cerveja"))categoria="Cerveja";
      else if(cat.includes("whisky")||cat.includes("vodka")||cat.includes("rum"))categoria="Destilado";
      else if(cat.includes("espumante")||cat.includes("champagne"))categoria="Espumante";
      else if(cat.includes("licor"))categoria="Licor";
      if(p.image_url)FOTOS[codigo]=p.image_url;
      mostrarProduto({codigo,nome,marca,categoria,quantidade:0,minimo:6,novo:true});return;
    }
  }catch{}
  try{
    const res=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},
      body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:200,messages:[{role:"user",content:`Código "${codigo}" de bebida. APENAS JSON: {"nome":"...","marca":"...","categoria":"Vinho|Cerveja|Destilado|Espumante|Licor|Outro"}`}]})});
    const data=await res.json();
    const parsed=JSON.parse(data.content.map(i=>i.text||"").join("").replace(/```json|```/g,"").trim());
    mostrarProduto({codigo,...parsed,quantidade:0,minimo:6,novo:true});
  }catch{mostrarProduto({codigo,nome:"Produto "+codigo.slice(-4),marca:"—",categoria:"Outro",quantidade:0,minimo:6,novo:true});}
}

