function renderChartBarras(){
  const map={};
  historico.filter(h=>h.tipo==="saida").forEach(h=>{map[h.produto]=(map[h.produto]||0)+h.qtd;});
  const sorted=Object.entries(map).sort((a,b)=>b[1]-a[1]).slice(0,6);
  const labels=sorted.map(([n])=>n.length>16?n.substring(0,15)+"…":n);
  const values=sorted.map(([,v])=>v);
  // Cores distintas por produto
  const CORES_BARRAS = ["#0f62fe","#7c3aed","#ea580c","#0d7a4e","#d97706","#db2777","#0891b2","#65a30d"];
  const bgColors = values.map((_,i) => CORES_BARRAS[i % CORES_BARRAS.length]);

  if(chartBarras)chartBarras.destroy();
  chartBarras=new Chart(document.getElementById("chart-barras").getContext("2d"),{
    type:"bar",
    data:{labels,datasets:[{data:values,backgroundColor:bgColors,borderRadius:4,borderSkipped:false}]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{backgroundColor:"#1c2533",titleColor:"#fff",bodyColor:"#9aa3b0",borderColor:"#e2e6ed",borderWidth:1}},
      scales:{x:{ticks:{color:"#9ca3af",font:{size:11,family:"Inter"}},grid:{display:false}},
              y:{ticks:{color:"#9ca3af",font:{size:11,family:"Inter"}},grid:{color:"#f3f4f6"},beginAtZero:true}}}
  });
}

function renderChartRosca(){
  const map={};
  estoque.forEach(p=>{map[p.categoria]=(map[p.categoria]||0)+p.quantidade;});
  const labels=Object.keys(map), values=Object.values(map), colors=labels.map(l=>CAT_CORES[l]||"#94a3b8");
  if(chartRosca)chartRosca.destroy();
  chartRosca=new Chart(document.getElementById("chart-rosca").getContext("2d"),{
    type:"doughnut",
    data:{labels,datasets:[{data:values,backgroundColor:colors,borderColor:"#fff",borderWidth:3,hoverBorderColor:"#fff"}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:"65%",
      plugins:{legend:{position:"right",labels:{color:"#374151",font:{size:11,family:"Inter"},padding:14,boxWidth:10,boxHeight:10,borderRadius:2}},
               tooltip:{backgroundColor:"#1c2533",titleColor:"#fff",bodyColor:"#9aa3b0",borderColor:"#e2e6ed",borderWidth:1}}}
  });
}

