function fpSelecionarForma(num, forma) {
  if (!window._fp) window._fp = { f1: null, f2: null };
  document.querySelectorAll(`#fp-${num === 1 ? "1" : "2"}-dinheiro, #fp-${num === 1 ? "1" : "2"}-pix, #fp-${num === 1 ? "1" : "2"}-cartao`).forEach(b => b.classList.remove("selected"));
  document.getElementById(`fp-${num}-${forma === "Dinheiro" ? "dinheiro" : forma === "Pix" ? "pix" : "cartao"}`).classList.add("selected");
  window._fp[`f${num}`] = forma;
  if (num === 2) document.getElementById("fp-valor2-box").style.display = "block";
  fpAtualizarRestante();
}

function fpAtualizarRestante() {
  if (!window._fp) return;
  const saldo = saldoCliente(clienteAtual);
  const v1 = parseFloat(document.getElementById("fp-valor-1").value) || 0;
  const v2 = parseFloat(document.getElementById("fp-valor-2").value) || 0;
  const restante = Math.max(0, saldo - v1);
  document.getElementById("fp-restante").textContent = "R$ " + restante.toFixed(2).replace(".",",");
  // Troco se tiver dinheiro
  const temDinheiro = window._fp.f1 === "Dinheiro" || window._fp.f2 === "Dinheiro";
  const totalPago = window._fp.f2 ? v1 + v2 : v1;
  const troco = totalPago - saldo;
  if (temDinheiro && totalPago > 0) {
    document.getElementById("fp-troco-box").style.display = "block";
    document.getElementById("fp-troco-valor").textContent = troco >= 0 ? "R$ " + troco.toFixed(2).replace(".",",") : "⚠️ Falta R$ " + Math.abs(troco).toFixed(2).replace(".",",");
    document.getElementById("fp-troco-valor").style.color = troco >= 0 ? "var(--blue)" : "var(--red)";
  } else {
    document.getElementById("fp-troco-box").style.display = "none";
  }
  // Habilitar botão
  const f1ok = window._fp.f1 && v1 > 0;
  const somentef1 = f1ok && !window._fp.f2 && v1 > 0;
  const f2ok = window._fp.f2 && v2 > 0;
  document.getElementById("fp-confirmar-btn").disabled = !(somentef1 || (f1ok && f2ok));
}

async function confirmarPagamentoFiado() {
  if (!window._fp?.f1) return;
  const saldo = saldoCliente(clienteAtual);
  const v1 = parseFloat(document.getElementById("fp-valor-1").value) || 0;
  const v2 = parseFloat(document.getElementById("fp-valor-2").value) || 0;
  const f1 = window._fp.f1;
  const f2 = window._fp.f2;
  const totalPago = f2 ? v1 + v2 : v1;
  const valor = Math.min(totalPago, saldo); // não abater mais que o saldo
  const formaLabel = f2 ? `${f1} R$${v1.toFixed(2)} + ${f2} R$${v2.toFixed(2)}` : f1;
  const now = new Date();
  const data = now.toLocaleDateString("pt-BR");
  const hora = now.toLocaleTimeString("pt-BR",{hour:"2-digit",minute:"2-digit"});
  const { data: lanc, error } = await db
    .from('fiado_lancamentos')
    .insert([{ fiado_cliente_id: clienteAtual.id, tipo:"credito", descricao:`Pagamento — ${formaLabel}`, valor, data, hora }])
    .select().single();
  if (error) { toast("Erro ao registrar pagamento.", "error"); console.error(error); return; }
  clienteAtual.lancamentos.push(lanc);
  fecharPagamento();
  renderDetalhe();
  renderFiado();
  toast(`✅ Pagamento de R$ ${valor.toFixed(2).replace(".",",")} registrado!`, "ok");
}

async function excluirCliente() {
  if (!clienteAtual) return;
  if (!confirm(`Excluir o cliente "${clienteAtual.nome}"? Esta ação não pode ser desfeita.`)) return;
  await db.from('fiado_lancamentos').delete().eq('fiado_cliente_id', clienteAtual.id);
  await db.from('fiado_clientes').delete().eq('id', clienteAtual.id);
  clientes = clientes.filter(c => c.id !== clienteAtual.id);
  fecharDetalhe();
  renderFiado();
  toast("Cliente excluído.", "ok");
}

