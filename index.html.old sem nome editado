function saldoCliente(c) {
  return (c.lancamentos||[]).reduce((a,l) => l.tipo==="debito" ? a+l.valor : a-l.valor, 0);
}

async function carregarFiado() {
  const { data: fclientes } = await db
    .from('fiado_clientes')
    .select('*, fiado_lancamentos(*)')
    .eq('cliente_id', _clienteId)
    .order('criado_em', { ascending: true });
  if (fclientes) {
    clientes = fclientes.map(c => ({
      ...c,
      lancamentos: (c.fiado_lancamentos || []).sort((a,b) => new Date(a.criado_em) - new Date(b.criado_em))
    }));
  }
  renderFiado();
}

function renderFiado() {
  const busca = (document.getElementById("fiado-busca")?.value||"").toLowerCase();
  const lista = clientes.filter(c => c.nome.toLowerCase().includes(busca));

  const totalAberto = clientes.reduce((a,c) => a + Math.max(0, saldoCliente(c)), 0);
  const comSaldo    = clientes.filter(c => saldoCliente(c) > 0).length;
  const el = (id) => document.getElementById(id);
  if(el("fiado-kpi-total"))   el("fiado-kpi-total").textContent   = "R$ " + totalAberto.toFixed(2).replace(".",",");
  if(el("fiado-kpi-clientes"))el("fiado-kpi-clientes").textContent = comSaldo;
  if(el("fiado-kpi-todos"))   el("fiado-kpi-todos").textContent    = clientes.length;

  if(!el("fiado-lista-clientes")) return;
  el("fiado-lista-clientes").innerHTML = lista.length === 0
    ? '<div class="empty-state" style="padding:28px">Nenhum cliente encontrado.</div>'
    : lista.map(c => {
        const saldo = saldoCliente(c);
        const ini   = c.nome.trim().split(" ").map(p=>p[0]).slice(0,2).join("").toUpperCase();
        const cores = ["#2563eb","#7c3aed","#0d7a4e","#ea580c","#db2777","#0891b2","#b45309","#b8892a"];
        const cor   = cores[Math.abs(c.nome.charCodeAt(0)) % cores.length];
        return `<div class="fiado-cliente-row" onclick="abrirDetalhe('${c.id}')">
          <div class="fiado-avatar" style="background:${cor}">${ini}</div>
          <div class="fiado-cliente-info">
            <div class="fiado-cliente-nome">${c.nome}</div>
            <div class="fiado-cliente-sub">${c.telefone||"Sem telefone"}${c.obs?" · "+c.obs:""}</div>
          </div>
          <div class="fiado-valor">
            <div class="fiado-valor-num ${saldo>0?"deve":"ok"}">R$ ${Math.abs(saldo).toFixed(2).replace(".",",")}</div>
            <div class="fiado-valor-label">${saldo>0?"em aberto":"quite"}</div>
          </div>
        </div>`;
      }).join("");
}

