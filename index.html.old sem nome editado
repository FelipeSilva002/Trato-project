async function salvarEdicao() {
  const codigo = document.getElementById("edit-codigo").value;
  const p = estoque.find(x => x.codigo === codigo);
  if (!p) return;

  const novaImagem = document.getElementById("edit-imagem-url").value.trim();

  const updates = {
    nome:       document.getElementById("edit-nome").value.trim() || p.nome,
    marca:      document.getElementById("edit-marca").value.trim() || p.marca,
    categoria:  document.getElementById("edit-categoria").value,
    quantidade: parseInt(document.getElementById("edit-quantidade").value) || 0,
    minimo:     parseInt(document.getElementById("edit-minimo").value) || 1,
    preco:      parseFloat(document.getElementById("edit-preco").value) || 0,
    imagem_url: novaImagem || null,
  };

  const { error } = await db
    .from('produtos')
    .update(updates)
    .eq('id', p.id);

  if (error) {
    toast("Erro ao atualizar produto.", "error");
    console.error(error);
    return;
  }

  Object.assign(p, updates);
  FOTOS[codigo] = novaImagem || null;
  fecharEdicao();
  renderProdutos();
  renderDashboard();
  toast("Produto atualizado com sucesso!", "ok");
