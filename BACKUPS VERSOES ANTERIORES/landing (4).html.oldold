  <script>
    // NAV scroll
    window.addEventListener('scroll', () => {
      document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 20);
    });

    // Responsivo nav btn
    if (window.innerWidth <= 900) {
      document.getElementById('nav-mob-btn').style.display = 'block';
    }

    // Fade-up on scroll
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

function toggleForm() {
  const form = document.getElementById("emailForm");
  form.classList.toggle("active");
}
  </script>

  <script>
    // ── Carrossel ──
    let currentSlide = 0;
    const slides = document.querySelectorAll('.cslide');
    const navLabels = document.querySelectorAll('.cnl');
    const total = slides.length;
    let autoTimer = null;

    function buildDots() {
      const dotsEl = document.getElementById('carouselDots');
      if (!dotsEl) return;
      dotsEl.innerHTML = '';
      for (let i = 0; i < total; i++) {
        const d = document.createElement('div');
        d.className = 'cdot' + (i === 0 ? ' active' : '');
        d.onclick = () => goToSlide(i);
        dotsEl.appendChild(d);
      }
    }

    function updateCarousel() {
      slides.forEach((s, i) => s.classList.toggle('active', i === currentSlide));
      navLabels.forEach((l, i) => l.classList.toggle('active', i === currentSlide));
      const dots = document.querySelectorAll('.cdot');
      dots.forEach((d, i) => d.classList.toggle('active', i === currentSlide));
    }

    function goToSlide(n) {
      currentSlide = (n + total) % total;
      updateCarousel();
      resetAuto();
    }

    function carouselNext() { goToSlide(currentSlide + 1); }
    function carouselPrev() { goToSlide(currentSlide - 1); }

    function startAuto() { autoTimer = setInterval(() => goToSlide(currentSlide + 1), 4000); }
    function resetAuto() { clearInterval(autoTimer); startAuto(); }

    buildDots();
    startAuto();

    const wrap = document.querySelector('.carousel-wrap');
    if (wrap) {
      wrap.addEventListener('mouseenter', () => clearInterval(autoTimer));
      wrap.addEventListener('mouseleave', startAuto);
    }
  </script>

</body>
</html>