<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trato — Controle total do seu negócio</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="icon" href="https://lyywnhaqikolhemgmjia.supabase.co/storage/v1/object/public/logos/favicon.png" type="image/png">
  <style>
    :root {
      --azul-escuro: #1a2e5a;
      --azul-medio: #1e6fa8;
      --teal: #2ab5c5;
      --teal-light: #4dd0de;
      --fundo: #f4f4f6;
      --branco: #ffffff;
      --texto: #1a2e5a;
      --texto-suave: #4a5f82;
      --borda: rgba(26,46,90,0.1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      color: var(--texto);
      overflow-x: hidden;
      margin: 0;
      padding: 0;
      position: relative;
      background: linear-gradient(160deg, #f0f4fa 0%, #e8eef8 40%, #f4f6fb 100%);
    }
    body::before,
body::after {
  content: "";
  position: fixed; /* <- importante */
  width: 500px;
  height: 500px;
  border-radius: 50%;
  filter: blur(120px);
  z-index: -1;
}

body::before {
  background: rgba(0, 150, 255, 0.15);
  top: -150px;
  left: -150px;
}

body::after {
  background: rgba(0, 200, 150, 0.15);
  bottom: -150px;
  right: -150px;
}


    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 5%;
      background: rgba(240,244,250,0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(26,46,90,0.08);
      transition: box-shadow .3s, background .3s;
    }
    nav.scrolled { box-shadow: 0 4px 24px rgba(26,46,90,0.08); }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }
    .nav-logo svg { width: 36px; height: 36px; }
    .nav-logo-texto {
      font-family: 'Montserrat', sans-serif;
      font-weight: 900;
      font-size: 22px;
      color: var(--azul-escuro);
      letter-spacing: -0.5px;
    }
    .nav-logo-texto span { color: var(--teal); }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 32px;
      list-style: none;
    }
    .nav-links a {
      font-size: 14px;
      font-weight: 500;
      color: var(--texto-suave);
      text-decoration: none;
      transition: color .2s;
    }
    .nav-links a:hover { color: var(--azul-escuro); }

    .btn-nav {
      padding: 10px 24px;
      background: var(--azul-escuro);
      color: #fff !important;
      border-radius: 8px;
      font-weight: 600 !important;
      font-size: 14px !important;
      transition: background .2s, transform .15s !important;
    }
    .btn-nav:hover { background: var(--azul-medio) !important; transform: translateY(-1px); }

    /* ── HERO ── */
    .hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 100px 4% 60px;
  position: relative;
  overflow: hidden;

  /* seu fundo atual */
  background: linear-gradient(160deg, #f0f4fa 0%, #e8eef8 40%, #f4f6fb 100%);
}

/* efeitos decorativos */
.hero::before,
.hero::after {
  content: "";
  position: absolute;
  width: 500px;
  height: 500px;
  border-radius: 50%;
  filter: blur(120px);
  z-index: 0;
}

/* luz azul (esquerda) */
.hero::before {
  background: rgba(0, 150, 255, 0.15);
  top: -150px;
  left: -150px;
}

/* luz verde/teal (direita) */
.hero::after {
  background: rgba(0, 200, 150, 0.15);
  bottom: -150px;
  right: -150px;
}

    .hero-grid {
      position: absolute;
      inset: 0;
      background-image: 
        linear-gradient(rgba(26,46,90,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(26,46,90,0.04) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
      z-index: 0;
    }

    .hero > * { position: relative; z-index: 1; }
    .hero-inner { position: relative; z-index: 1; }

    .hero::before,
.hero::after {
  animation: float 8s ease-in-out infinite;
}

@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(20px); }
  100% { transform: translateY(0px); }
}

    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
      max-width: 1500px;
      margin: 0 auto;
      width: 100%;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(42,181,197,0.1);
      border: 1px solid rgba(42,181,197,0.3);
      color: var(--azul-medio);
      font-size: 12px;
      font-weight: 600;
      padding: 6px 14px;
      border-radius: 100px;
      margin-bottom: 24px;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }
    .hero-badge::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--teal);
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: .5; transform: scale(1.3); }
    }

    .hero h1 {
      font-family: 'Montserrat', sans-serif;
      font-size: clamp(36px, 4.5vw, 58px);
      font-weight: 900;
      line-height: 1.1;
      color: var(--azul-escuro);
      margin-bottom: 20px;
      letter-spacing: -1px;
    }
    .hero h1 .destaque {
      background: linear-gradient(135deg, var(--azul-medio), var(--teal));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: 17px;
      color: var(--texto-suave);
      line-height: 1.7;
      margin-bottom: 40px;
      max-width: 480px;
    }

    .hero-ctas {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 15px 32px;
      background: linear-gradient(135deg, var(--azul-medio), var(--teal));
      color: #fff;
      border-radius: 10px;
      font-family: 'Montserrat', sans-serif;
      font-weight: 700;
      font-size: 15px;
      text-decoration: none;
      box-shadow: 0 8px 24px rgba(30,111,168,0.35);
      transition: transform .2s, box-shadow .2s;
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(30,111,168,0.45); }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 15px 32px;
      background: transparent;
      color: var(--azul-escuro);
      border: 2px solid var(--borda);
      border-radius: 10px;
      font-family: 'Montserrat', sans-serif;
      font-weight: 700;
      font-size: 15px;
      text-decoration: none;
      transition: border-color .2s, background .2s;
      cursor: pointer;
    }
    .btn-secondary:hover { border-color: var(--azul-medio); background: rgba(30,111,168,0.04); }

    /* Dashboard mockup */
    .hero-visual {
      position: relative;
    }

    .mockup {
      background: var(--azul-escuro);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 32px 80px rgba(26,46,90,0.25), 0 0 0 1px rgba(42,181,197,0.15);
      transform: perspective(1000px) rotateY(-6deg) rotateX(3deg);
      transition: transform .4s ease;
    }
    .mockup:hover { transform: perspective(1000px) rotateY(-2deg) rotateX(1deg); }

    .mockup-bar {
      background: #0f1e3d;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .mockup-dot { width: 10px; height: 10px; border-radius: 50%; }
    .mockup-dot:nth-child(1) { background: #ff5f57; }
    .mockup-dot:nth-child(2) { background: #febc2e; }
    .mockup-dot:nth-child(3) { background: #28c840; }
    .mockup-url {
      flex: 1;
      background: rgba(255,255,255,0.06);
      border-radius: 6px;
      padding: 5px 12px;
      font-size: 11px;
      color: rgba(255,255,255,0.4);
      font-family: monospace;
      margin-left: 8px;
    }

    .mockup-body {
      display: flex;
      min-height: 320px;
    }

    .mockup-sidebar {
      width: 60px;
      background: #0f1e3d;
      padding: 16px 8px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }
    .mockup-icon {
      width: 36px; height: 36px;
      border-radius: 8px;
      background: rgba(42,181,197,0.1);
      display: flex; align-items: center; justify-content: center;
    }
    .mockup-icon.active { background: var(--teal); }
    .mockup-icon svg { width: 16px; height: 16px; opacity: 0.7; }
    .mockup-icon.active svg { opacity: 1; }

    .mockup-content {
      flex: 1;
      padding: 20px;
      background: #1a2e5a;
    }

    .mockup-title {
      font-size: 13px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 16px;
      font-family: 'Montserrat', sans-serif;
    }

    .mockup-kpis {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 16px;
    }
    .mockup-kpi {
      background: rgba(255,255,255,0.06);
      border-radius: 8px;
      padding: 10px;
      border: 1px solid rgba(42,181,197,0.15);
    }
    .mockup-kpi-val {
      font-size: 15px;
      font-weight: 800;
      color: var(--teal-light);
      font-family: 'Montserrat', sans-serif;
    }
    .mockup-kpi-label { font-size: 9px; color: rgba(255,255,255,0.4); margin-top: 2px; }

    .mockup-bars {
      display: flex;
      align-items: flex-end;
      gap: 6px;
      height: 80px;
      margin-bottom: 14px;
    }
    .mockup-bar-item {
      flex: 1;
      border-radius: 4px 4px 0 0;
      background: linear-gradient(180deg, var(--teal), var(--azul-medio));
      opacity: 0.7;
      transition: opacity .2s;
    }
    .mockup-bar-item:hover { opacity: 1; }

    .mockup-table { width: 100%; }
    .mockup-row {
      display: flex;
      gap: 8px;
      padding: 6px 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      align-items: center;
    }
    .mockup-cell { font-size: 9px; color: rgba(255,255,255,0.5); flex: 1; }
    .mockup-cell.green { color: #2ab5c5; }
    .mockup-cell.red { color: #ff6b6b; font-size: 8px; }
    .mockup-badge-ok {
      font-size: 8px;
      padding: 2px 6px;
      border-radius: 4px;
      background: rgba(42,181,197,0.15);
      color: var(--teal-light);
    }
    .mockup-badge-low {
      font-size: 8px;
      padding: 2px 6px;
      border-radius: 4px;
      background: rgba(255,107,107,0.15);
      color: #ff6b6b;
    }

    /* ── STATS ── */
    .stats {
      background: linear-gradient(135deg, #1a2e5a 0%, #0f1e3d 100%);
      padding: 52px 6%;
      position: relative;
      overflow: hidden;
    }
    .stats::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(42,181,197,0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(42,181,197,0.06) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
    }
    .stats-inner { position: relative; }
    .stats-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
      text-align: center;
    }
    .stat-num {
      font-family: 'Montserrat', sans-serif;
      font-size: 42px;
      font-weight: 900;
      color: var(--teal-light);
      line-height: 1;
      margin-bottom: 8px;
    }
    .stat-label { font-size: 14px; color: rgba(255,255,255,0.5); }

    /* ── FEATURES ── */
    .features {
      padding: 72px 6%;
      background: var(--fundo);
    }
    .section-tag {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--teal);
      margin-bottom: 12px;
    }
    .section-title {
      font-family: 'Montserrat', sans-serif;
      font-size: clamp(28px, 3vw, 42px);
      font-weight: 900;
      color: var(--azul-escuro);
      margin-bottom: 16px;
      letter-spacing: -0.5px;
    }
    .section-sub {
      font-size: 16px;
      color: var(--texto-suave);
      max-width: 500px;
      line-height: 1.7;
      margin-bottom: 40px;
    }

    .features-grid {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .feature-card {
      background: var(--branco);
      border-radius: 16px;
      padding: 32px;
      border: 1px solid var(--borda);
      transition: transform .3s, box-shadow .3s, border-color .3s;
      position: relative;
      overflow: hidden;
    }
    .feature-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--azul-medio), var(--teal));
      opacity: 0;
      transition: opacity .3s;
    }
    .feature-card:hover { transform: translateY(-8px); box-shadow: 0 24px 56px rgba(26,46,90,0.13); border-color: rgba(42,181,197,0.3); }
    .feature-card:hover::before { opacity: 1; }

    .feature-icon {
      width: 52px; height: 52px;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(30,111,168,0.1), rgba(42,181,197,0.15));
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 20px;
    }
    .feature-icon svg { width: 24px; height: 24px; color: var(--azul-medio); }

    .feature-title {
      font-family: 'Montserrat', sans-serif;
      font-size: 17px;
      font-weight: 800;
      color: var(--azul-escuro);
      margin-bottom: 10px;
    }
    .feature-desc { font-size: 14px; color: var(--texto-suave); line-height: 1.7; }

    /* ── SEGMENTOS ── */
    .segmentos {
      padding: 72px 6%;
      background: linear-gradient(160deg, #eaeff8 0%, var(--fundo) 100%);
    }
    .segmentos-inner { max-width: 1200px; margin: 0 auto; }
    .segmentos-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-top: 60px;
    }
    .segmento-card:last-child {
      grid-column: 2;
    }
    .segmento-card {
      background: var(--branco);
      border-radius: 16px;
      padding: 28px 24px;
      text-align: center;
      border: 2px solid transparent;
      transition: border-color .3s, transform .3s, box-shadow .3s;
      cursor: default;
    }
    .segmento-card:hover { border-color: var(--teal); transform: translateY(-4px); box-shadow: 0 16px 40px rgba(42,181,197,0.12); }
    .segmento-emoji { font-size: 36px; margin-bottom: 14px; }
    .segmento-nome {
      font-family: 'Montserrat', sans-serif;
      font-size: 15px;
      font-weight: 800;
      color: var(--azul-escuro);
      margin-bottom: 8px;
    }
    .segmento-desc { font-size: 12px; color: var(--texto-suave); line-height: 1.6; }

    /* ── PRECOS ── */
    .precos {
      padding: 72px 6%;
      background: var(--fundo);
    }
    .precos-inner { max-width: 1200px; margin: 0 auto; }
    .precos-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 60px;
    }
    .preco-card {
      background: var(--branco);
      border-radius: 20px;
      padding: 40px 32px;
      border: 2px solid var(--borda);
      position: relative;
      transition: transform .3s, box-shadow .3s;
    }
    .preco-card:hover { transform: translateY(-6px); box-shadow: 0 24px 60px rgba(26,46,90,0.1); }
    .preco-card.destaque {
      background: var(--azul-escuro);
      border-color: var(--teal);
      box-shadow: 0 24px 60px rgba(26,46,90,0.25);
    }
    .preco-badge {
      position: absolute;
      top: -14px; left: 50%;
      transform: translateX(-50%);
      background: linear-gradient(135deg, var(--azul-medio), var(--teal));
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      padding: 5px 16px;
      border-radius: 100px;
      white-space: nowrap;
      font-family: 'Montserrat', sans-serif;
    }
    .preco-nome {
      font-family: 'Montserrat', sans-serif;
      font-size: 14px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--texto-suave);
      margin-bottom: 16px;
    }
    .preco-card.destaque .preco-nome { color: rgba(255,255,255,0.5); }
    .preco-valor {
      font-family: 'Montserrat', sans-serif;
      font-size: 48px;
      font-weight: 900;
      color: var(--azul-escuro);
      line-height: 1;
      margin-bottom: 4px;
    }
    .preco-card.destaque .preco-valor { color: var(--teal-light); }
    .preco-valor sup { font-size: 20px; vertical-align: super; }
    .preco-valor span { font-size: 16px; font-weight: 500; }
    .preco-periodo { font-size: 13px; color: var(--texto-suave); margin-bottom: 28px; }
    .preco-card.destaque .preco-periodo { color: rgba(255,255,255,0.4); }
    .preco-divider { height: 1px; background: var(--borda); margin-bottom: 28px; }
    .preco-card.destaque .preco-divider { background: rgba(255,255,255,0.1); }
    .preco-lista { list-style: none; margin-bottom: 32px; }
    .preco-lista li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 14px;
      color: var(--texto-suave);
      padding: 7px 0;
      border-bottom: 1px solid rgba(26,46,90,0.04);
    }
    .preco-card.destaque .preco-lista li { color: rgba(255,255,255,0.7); border-bottom-color: rgba(255,255,255,0.05); }
    .preco-lista li::before {
      content: '✓';
      color: var(--teal);
      font-weight: 700;
      font-size: 13px;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .btn-preco {
      display: block;
      text-align: center;
      padding: 14px;
      border-radius: 10px;
      font-family: 'Montserrat', sans-serif;
      font-weight: 700;
      font-size: 14px;
      text-decoration: none;
      transition: all .2s;
      cursor: pointer;
      border: none;
      width: 100%;
    }
    .btn-preco-outline {
      background: transparent;
      border: 2px solid var(--borda);
      color: var(--azul-escuro);
    }
    .btn-preco-outline:hover { border-color: var(--azul-medio); background: rgba(30,111,168,0.04); }
    .btn-preco-filled {
      background: linear-gradient(135deg, var(--azul-medio), var(--teal));
      color: #fff;
      box-shadow: 0 8px 24px rgba(30,111,168,0.35);
    }
    .btn-preco-filled:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(30,111,168,0.45); }

    /* ── CONTATO ── */
    .contato-box {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      background: var(--branco);
      border-radius: 20px;
      padding: 48px;
      border: 1px solid rgba(26,46,90,0.08);
      box-shadow: 0 16px 48px rgba(26,46,90,0.07);
      margin-top: 48px;
      align-items: center;
    }
    .contato-icone {
      width: 64px; height: 64px;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(30,111,168,0.1), rgba(42,181,197,0.15));
      display: flex; align-items: center; justify-content: center;
      color: var(--azul-medio);
      margin-bottom: 20px;
    }
    .contato-titulo {
      font-family: 'Montserrat', sans-serif;
      font-size: 26px;
      font-weight: 900;
      color: var(--azul-escuro);
      margin-bottom: 12px;
    }
    .contato-desc { font-size: 15px; color: var(--texto-suave); line-height: 1.7; margin-bottom: 28px; }
    .contato-btns { display: flex; flex-direction: column; gap: 12px; }
    .btn-whatsapp {
      display: inline-flex; align-items: center; gap: 10px;
      padding: 14px 24px;
      background: #25d366; color: #fff;
      border-radius: 10px;
      font-family: 'Montserrat', sans-serif;
      font-weight: 700; font-size: 14px;
      text-decoration: none;
      transition: transform .2s, box-shadow .2s;
      box-shadow: 0 6px 20px rgba(37,211,102,0.3);
    }
    .btn-whatsapp:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(37,211,102,0.4); }
    .btn-email {
      display: inline-flex; align-items: center; gap: 10px;
      padding: 14px 24px;
      background: transparent; color: var(--azul-medio);
      border: 2px solid rgba(30,111,168,0.2);
      border-radius: 10px;
      font-family: 'Montserrat', sans-serif;
      font-weight: 600; font-size: 14px;
      text-decoration: none;
      transition: border-color .2s, background .2s;
      cursor: pointer;
    }
    .btn-email:hover { border-color: var(--azul-medio); background: rgba(30,111,168,0.04); }
    .contato-right { display: flex; flex-direction: column; gap: 20px; }
    .contato-item {
      display: flex; align-items: flex-start; gap: 14px;
      font-size: 15px; color: var(--texto-suave); line-height: 1.5;
    }
    .contato-item strong { color: var(--azul-escuro); }
    .contato-check {
      width: 26px; height: 26px; flex-shrink: 0;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--azul-medio), var(--teal));
      color: #fff;
      font-size: 12px; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
    }

    /* ── AVALIAÇÕES ── */
    .avaliacoes {
      padding: 72px 6%;
      background: linear-gradient(160deg, #eaeff8 0%, var(--fundo) 100%);
    }
    .avaliacoes-inner { max-width: 1200px; margin: 0 auto; }
    .avaliacoes-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 60px;
    }
    .avaliacao-card {
      background: var(--branco);
      border-radius: 20px;
      padding: 32px;
      border: 1px solid var(--borda);
      position: relative;
      transition: transform .3s, box-shadow .3s;
    }
    .avaliacao-card:hover { transform: translateY(-5px); box-shadow: 0 20px 50px rgba(26,46,90,0.09); }
    .avaliacao-aspas {
      font-size: 56px;
      line-height: 1;
      color: var(--teal);
      opacity: 0.25;
      font-family: Georgia, serif;
      position: absolute;
      top: 16px; left: 24px;
    }
    .avaliacao-estrelas {
      display: flex; gap: 3px;
      margin-bottom: 16px;
    }
    .avaliacao-estrelas span { font-size: 18px; }
    .avaliacao-texto {
      font-size: 15px;
      color: var(--texto-suave);
      line-height: 1.75;
      margin-bottom: 24px;
      font-style: italic;
    }
    .avaliacao-autor {
      display: flex; align-items: center; gap: 12px;
      border-top: 1px solid var(--borda);
      padding-top: 20px;
    }
    .avaliacao-avatar {
      width: 44px; height: 44px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Montserrat', sans-serif;
      font-weight: 800; font-size: 16px;
      color: #fff;
      flex-shrink: 0;
    }
    .avaliacao-nome {
      font-family: 'Montserrat', sans-serif;
      font-weight: 700;
      font-size: 14px;
      color: var(--azul-escuro);
    }
    .avaliacao-cargo { font-size: 12px; color: var(--texto-suave); margin-top: 2px; }

    @media (max-width: 900px) {
      .contato-box { grid-template-columns: 1fr; padding: 36px 28px; }
      .avaliacoes-grid { grid-template-columns: 1fr; }
    }

    /* ── PRECOS RESPONSIVO ── */
    @media (max-width: 900px) {
      .precos-grid { grid-template-columns: 1fr; max-width: 400px; margin: 60px auto 0; }
    }

    /* ── CTA FINAL ── */
    .cta-final {
      padding: 80px 6%;
      background: linear-gradient(145deg, #1a2e5a 0%, #0d1f42 60%, #152848 100%);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-final::before {
      content: '';
      position: absolute;
      top: -200px; left: 50%;
      transform: translateX(-50%);
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(42,181,197,0.1) 0%, transparent 70%);
    }
    .cta-final h2 {
      font-family: 'Montserrat', sans-serif;
      font-size: clamp(28px, 3.5vw, 48px);
      font-weight: 900;
      color: #fff;
      margin-bottom: 16px;
      position: relative;
    }
    .cta-final p {
      font-size: 17px;
      color: rgba(255,255,255,0.5);
      margin-bottom: 40px;
      position: relative;
    }
    .cta-final-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; position: relative; }

    /* ── FOOTER ── */
    footer {
      background: #0a1628;
      padding: 28px 6%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }
    .footer-logo {
      font-family: 'Montserrat', sans-serif;
      font-weight: 900;
      font-size: 18px;
      color: rgba(255,255,255,0.7);
    }
    .footer-logo span { color: var(--teal); }
    .footer-copy { font-size: 13px; color: rgba(255,255,255,0.3); }

    /* ── MODAL LOGIN ── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(10,20,50,0.7);
      backdrop-filter: blur(6px);
      z-index: 1000;
      align-items: center;
      justify-content: center;
    }
    .modal-overlay.open { display: flex; }

    .modal-box {
      background: var(--branco);
      border-radius: 20px;
      padding: 48px 40px;
      width: 100%;
      max-width: 420px;
      position: relative;
      box-shadow: 0 40px 100px rgba(10,20,50,0.4);
      animation: slideUp .3s ease;
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .modal-close {
      position: absolute;
      top: 16px; right: 16px;
      width: 32px; height: 32px;
      border-radius: 8px;
      border: none;
      background: var(--fundo);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      color: var(--texto-suave);
      font-size: 18px;
      transition: background .2s;
    }
    .modal-close:hover { background: var(--borda); }

    .modal-logo {
      text-align: center;
      margin-bottom: 8px;
    }
    .modal-logo-text {
      font-family: 'Montserrat', sans-serif;
      font-weight: 900;
      font-size: 26px;
      color: var(--azul-escuro);
    }
    .modal-logo-text span { color: var(--teal); }
    .modal-sub {
      text-align: center;
      font-size: 13px;
      color: var(--texto-suave);
      margin-bottom: 32px;
    }

    .form-group { margin-bottom: 18px; }
    .form-label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: var(--azul-escuro);
      margin-bottom: 7px;
      letter-spacing: 0.3px;
    }
    .form-input {
      width: 100%;
      padding: 12px 14px;
      border: 2px solid var(--borda);
      border-radius: 10px;
      font-size: 14px;
      font-family: 'Inter', sans-serif;
      color: var(--texto);
      background: var(--fundo);
      transition: border-color .2s, box-shadow .2s;
      outline: none;
    }
    .form-input:focus {
      border-color: var(--teal);
      box-shadow: 0 0 0 3px rgba(42,181,197,0.1);
      background: #fff;
    }

    .form-erro {
      background: rgba(255,80,80,0.08);
      border: 1px solid rgba(255,80,80,0.2);
      color: #c0392b;
      font-size: 13px;
      padding: 10px 14px;
      border-radius: 8px;
      margin-bottom: 16px;
      display: none;
    }
    .form-erro.show { display: block; }

    .btn-login {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, var(--azul-medio), var(--teal));
      color: #fff;
      border: none;
      border-radius: 10px;
      font-family: 'Montserrat', sans-serif;
      font-weight: 700;
      font-size: 15px;
      cursor: pointer;
      box-shadow: 0 8px 24px rgba(30,111,168,0.3);
      transition: transform .2s, box-shadow .2s;
      margin-top: 8px;
    }
    .btn-login:hover { transform: translateY(-1px); box-shadow: 0 12px 30px rgba(30,111,168,0.4); }
    .btn-login:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    .modal-footer-text {
      text-align: center;
      font-size: 11px;
      color: var(--texto-suave);
      margin-top: 20px;
    }

    /* ── ANIMAÇÕES ENTRADA ── */
    .fade-up {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity .6s ease, transform .6s ease;
    }
    .fade-up.visible { opacity: 1; transform: translateY(0); }

    /* ── RESPONSIVO ── */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-visual { display: none; }
      .features-grid { grid-template-columns: 1fr 1fr; }
      .segmentos-grid { grid-template-columns: 1fr 1fr; }
      .segmento-card:last-child { grid-column: auto; }
      .stats-inner { grid-template-columns: 1fr 1fr; }
      .nav-links { display: none; }
    }
    @media (max-width: 600px) {
      .features-grid { grid-template-columns: 1fr; }
      .segmentos-grid { grid-template-columns: 1fr 1fr; }
      .segmento-card:last-child { grid-column: auto; }
      .stats-inner { grid-template-columns: 1fr 1fr; }
      .modal-box { padding: 36px 24px; margin: 16px; }
    }

    /* ── HERO TOPBAR ── */
    .hero-topbar {
      position: absolute;
      top: 70px;
      left: 0; right: 0;
      display: flex;
      justify-content: center;
      z-index: 10;
      pointer-events: none;
    }
    .hero-topbar-inner {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: rgba(255,255,255,0.88);
      border: 1px solid rgba(42,181,197,0.25);
      backdrop-filter: blur(12px);
      padding: 9px 20px;
      border-radius: 100px;
      font-size: 13px;
      color: var(--azul-escuro);
      box-shadow: 0 4px 20px rgba(26,46,90,0.10);
      pointer-events: auto;
    }
    .hero-topbar-inner strong { color: var(--azul-medio); }
    .hero-topbar-pill { font-size: 14px; }
    .hero-topbar-arrow { color: var(--teal); font-weight: 700; }

    /* ── CARROSSEL ── */
    .carousel-wrap {
      position: relative;
      width: 100%;
    }

    .carousel-track {
      position: relative;
      width: 100%;
    }

    .cslide {
      display: none;
      flex-direction: column;
      gap: 12px;
    }
    .cslide.active { display: flex; }

    .cslide-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--teal);
      text-align: center;
    }

    /* Labels de navegação */
    .carousel-nav-labels {
      display: flex;
      gap: 6px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 14px;
    }
    .cnl {
      font-size: 11px;
      font-weight: 600;
      color: rgba(26,46,90,0.4);
      cursor: pointer;
      padding: 4px 12px;
      border-radius: 100px;
      border: 1px solid transparent;
      transition: all .2s;
      user-select: none;
    }
    .cnl:hover { color: var(--azul-medio); }
    .cnl.active {
      color: var(--azul-medio);
      background: rgba(42,181,197,0.1);
      border-color: rgba(42,181,197,0.3);
    }

    /* Botões prev/next */
    .carousel-controls {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      margin-top: 12px;
    }
    .carousel-btn {
      background: rgba(26,46,90,0.08);
      border: 1px solid rgba(26,46,90,0.12);
      color: var(--azul-escuro);
      width: 32px; height: 32px;
      border-radius: 50%;
      font-size: 18px;
      line-height: 1;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background .2s, transform .15s;
      user-select: none;
    }
    .carousel-btn:hover { background: rgba(42,181,197,0.15); transform: scale(1.05); }

    .carousel-dots { display: flex; gap: 6px; }
    .cdot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: rgba(26,46,90,0.2);
      cursor: pointer;
      transition: background .2s, transform .2s;
    }
    .cdot.active { background: var(--teal); transform: scale(1.3); }

    /* PDV cards */
    .pdv-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(42,181,197,0.12);
      border-radius: 8px;
      padding: 8px 6px;
      text-align: center;
      cursor: pointer;
      transition: background .2s;
      font-size: 16px;
    }
    .pdv-card:hover { background: rgba(42,181,197,0.1); }
    .pdv-name { font-size: 8px; color: rgba(255,255,255,0.5); margin-top: 3px; }
    .pdv-price { font-size: 9px; color: #2ab5c5; font-weight: 700; }
    .pdv-add { background: rgba(42,181,197,0.08); border-style: dashed; color: rgba(255,255,255,0.3); font-size: 18px; display:flex;flex-direction:column;align-items:center;justify-content:center; }

    .cart-row { display: flex; justify-content: space-between; font-size: 8px; color: rgba(255,255,255,0.4); }

    /* Fiado cards */
    .fiado-card {
      display: flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,0.04);
      border-radius: 8px;
      padding: 8px 10px;
      border: 1px solid rgba(255,255,255,0.04);
    }
    .fiado-avatar {
      width: 28px; height: 28px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 9px; font-weight: 700; color: #fff;
      flex-shrink: 0;
    }
    .fiado-name { font-size: 9px; font-weight: 700; color: rgba(255,255,255,0.7); }
    .fiado-items { font-size: 8px; color: rgba(255,255,255,0.3); margin-top: 2px; }
    .fiado-valor { font-size: 11px; font-weight: 800; font-family: 'Montserrat', sans-serif; margin-left: auto; }
    .fiado-valor.red { color: #ff6b6b; }

    /* animação de entrada do slide */
    @keyframes slideIn {
      from { opacity: 0; transform: translateX(20px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    .cslide.active { animation: slideIn .35s ease; }

    /* ── TOP-BAR PILL ── */
    .topbar-pill {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: rgba(255,255,255,0.75);
      border: 1px solid rgba(42,181,197,0.2);
      backdrop-filter: blur(10px);
      padding: 6px 16px;
      border-radius: 100px;
      font-size: 12.5px;
      color: var(--azul-escuro);
      box-shadow: 0 2px 12px rgba(26,46,90,0.07);
      white-space: nowrap;
    }
    .topbar-stars { font-size: 10px; letter-spacing: 1px; }
    .topbar-sep {
      width: 1px; height: 14px;
      background: rgba(26,46,90,0.12);
      flex-shrink: 0;
    }
    .topbar-msg { color: var(--texto-suave); font-size: 12px; }
    .topbar-msg strong { color: var(--azul-medio); font-weight: 700; }

    /* ── CORREÇÃO NAV: alinhar logo + pill + links ── */
    nav {
      flex-wrap: nowrap;
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav id="nav">
    
    <a href="#" class="nav-logo">
      <img style="height:44px;width:auto;mix-blend-mode:multiply;" src="data:image/png;base64," alt="Trato" style="height:100px;width:auto;object-fit:contain;">
    </a>
    <div class="topbar-pill">
      <span class="topbar-stars">⭐⭐⭐⭐⭐</span>
      <span class="topbar-sep"></span>
      <span class="topbar-msg">Mais de <strong>500 empresas</strong> já utilizam — adegas, mercadinhos, bares e mais</span>
    </div>
    <ul class="nav-links">
      <li><a href="#features">Funcionalidades</a></li>
      <li><a href="#segmentos">Segmentos</a></li>
      <li><a href="#precos">Preços</a></li>
      <li><a href="https://tratoapp.com.br/app" target="_blank" rel="noopener" class="btn-nav">Área do Cliente</a></li>
    </ul>
    <a href="https://tratoapp.com.br/app" target="_blank" rel="noopener" class="btn-nav" id="nav-mob-btn" style="display:none">Entrar</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid"></div>
    <!-- Faixa topo -->
    <div class="hero-topbar">
      <div class="hero-topbar-inner">
        <span class="hero-topbar-pill">⭐</span>
        <span>Mais de <strong>500 empresas</strong> já utilizam o sistema — de adegas a mercadinhos</span>
        <span class="hero-topbar-arrow">→</span>
      </div>
    </div>

    <div class="hero-inner">
      <div>
        <div class="hero-badge">Sistema de Gestão</div>
        <h1>Controle total do<br><span class="destaque">seu negócio</span></h1>
        <p class="hero-sub">PDV, estoque, fiado, relatórios e muito mais — tudo em um único sistema pensado para o comércio brasileiro.</p>
        <div class="hero-ctas">
          <a href="https://tratoapp.com.br/app" target="_blank" rel="noopener" class="btn-primary">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
            Área do Cliente
          </a>
          <a href="#features" class="btn-secondary">Ver funcionalidades</a>
        </div>
      </div>

      <!-- Carrossel -->
      <div class="hero-visual">
        <div class="carousel-wrap">
          <!-- Slides -->
          <div class="carousel-track" id="carouselTrack">

            <!-- SLIDE 1: Dashboard -->
            <div class="cslide active">
              <div class="cslide-label">Dashboard</div>
              <div class="mockup">
                <div class="mockup-bar">
                  <div class="mockup-dot"></div><div class="mockup-dot"></div><div class="mockup-dot"></div>
                  <div class="mockup-url">tratoapp.com.br/app</div>
                </div>
                <div class="mockup-body">
                  <div class="mockup-sidebar">
                    <div class="mockup-icon active"><svg viewBox="0 0 24 24" fill="white"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg></div>
                    <div class="mockup-icon"><svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg></div>
                    <div class="mockup-icon"><svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg></div>
                    <div class="mockup-icon"><svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div>
                    <div class="mockup-icon"><svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
                  </div>
                  <div class="mockup-content">
                    <div class="mockup-title">Dashboard</div>
                    <div class="mockup-kpis">
                      <div class="mockup-kpi"><div class="mockup-kpi-val">R$4.2k</div><div class="mockup-kpi-label">Vendas hoje</div></div>
                      <div class="mockup-kpi"><div class="mockup-kpi-val">87</div><div class="mockup-kpi-label">Transações</div></div>
                      <div class="mockup-kpi"><div class="mockup-kpi-val" style="color:#ff6b6b">12</div><div class="mockup-kpi-label">Alertas</div></div>
                    </div>
                    <div class="mockup-bars">
                      <div class="mockup-bar-item" style="height:45%"></div>
                      <div class="mockup-bar-item" style="height:65%"></div>
                      <div class="mockup-bar-item" style="height:40%"></div>
                      <div class="mockup-bar-item" style="height:80%"></div>
                      <div class="mockup-bar-item" style="height:55%"></div>
                      <div class="mockup-bar-item" style="height:90%"></div>
                      <div class="mockup-bar-item" style="height:70%"></div>
                    </div>
                    <div class="mockup-table">
                      <div class="mockup-row"><div class="mockup-cell">Heineken 350ml</div><div class="mockup-cell green">48 un.</div><div class="mockup-cell"><span class="mockup-badge-ok">OK</span></div></div>
                      <div class="mockup-row"><div class="mockup-cell">Vinho Tinto Seco</div><div class="mockup-cell red">3 un.</div><div class="mockup-cell"><span class="mockup-badge-low">Baixo</span></div></div>
                      <div class="mockup-row"><div class="mockup-cell">Whisky Johnnie</div><div class="mockup-cell green">12 un.</div><div class="mockup-cell"><span class="mockup-badge-ok">OK</span></div></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- SLIDE 2: PDV -->
            <div class="cslide">
              <div class="cslide-label">Ponto de Venda</div>
              <div class="mockup">
                <div class="mockup-bar">
